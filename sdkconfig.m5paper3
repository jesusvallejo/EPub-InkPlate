#
# M5 Paper S3 Specific SDK Configuration
# Based on M5_PAPER_S3 hardware specifications
#

# Core CPU Configuration
CONFIG_ESP32S3_SPIRAM_SUPPORT=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240

# PSRAM Configuration for M5 Paper S3 (8MB PSRAM)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_TYPE_AUTO=y
CONFIG_SPIRAM_SPEED_40M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MEMTEST=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_SPIRAM_CACHE_WORKAROUND=y
CONFIG_SPIRAM_CACHE_WORKAROUND_STRATEGY_MEMW=y
CONFIG_SPIRAM_BANKSWITCH_ENABLE=y
CONFIG_SPIRAM_BANKSWITCH_RESERVE=8

# GPIO Configuration (PSRAM Pin Mappings for ESP32-S3)
CONFIG_D0WD_PSRAM_CLK_IO=17
CONFIG_D0WD_PSRAM_CS_IO=16
CONFIG_D2WD_PSRAM_CLK_IO=9
CONFIG_D2WD_PSRAM_CS_IO=10
CONFIG_PICO_PSRAM_CS_IO=10
CONFIG_SPIRAM_SPIWP_SD3_PIN=7

# Network Configuration
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=1024
CONFIG_ESP_WIFI_STATIC_TX_BUFFER=y
CONFIG_ESP_WIFI_TX_BUFFER_TYPE=0
CONFIG_ESP_WIFI_STATIC_TX_BUFFER_NUM=16
CONFIG_ESP_WIFI_CACHE_TX_BUFFER_NUM=32
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# File System Configuration
CONFIG_FATFS_CODEPAGE_850=y
CONFIG_FATFS_CODEPAGE=850
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
CONFIG_FATFS_API_ENCODING_UTF_8=y
CONFIG_FATFS_FS_LOCK=5
CONFIG_FATFS_ALLOC_PREFER_EXTRAM=y

# Bootloader Configuration
CONFIG_BOOTLOADER_LOG_LEVEL_NONE=y
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y

# Compiler Optimization
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Partition Table (using shared partitions.csv)
CONFIG_PARTITION_TABLE_SINGLE_APP=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_CUSTOM=y

# Flash Configuration (M5 Paper S3 has 16MB Flash)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# Watchdog Configuration
CONFIG_ESP_TASK_WDT=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=n

# USB Serial JTAG for ESP32-S3 (M5 Paper S3 typical debug connection)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_USB_SERIAL_JTAG_RX_BUFFER_SIZE=64
CONFIG_USB_SERIAL_JTAG_TX_BUFFER_SIZE=64

# Deep sleep configuration for battery management
CONFIG_ESP_SLEEP_DEEP_SLEEP_WAKEUP_DELAY=2000
CONFIG_ESP_SLEEP_GPIO_RESET_BY_BOOTLOADER=y
CONFIG_RTC_CLK_CAL_CYCLES=1024

# ADC Configuration for battery monitoring
CONFIG_ADC_CAL_LUT_ENABLE=y
CONFIG_ADC_CAL_EFUSE_LS_BIT_LEN_0=0
CONFIG_ADC_CAL_EFUSE_LS_BIT_LEN_1=0
CONFIG_ADC_CAL_EFUSE_LS_BIT_LEN_2=0

# I2C Configuration (for touch, RTC, power management on M5 Paper S3)
CONFIG_I2C_ENABLE_STATUS_DEBUG_INFO=n

# SPI Configuration (for IT8951E display and SD card on M5 Paper S3)
CONFIG_SPI_MASTER_ISR_IN_IRAM=n
CONFIG_SPI_SLAVE_ISR_IN_IRAM=n

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3
